# =======================================================================
# TMPVL AuditIQ — Environment Configuration Template
# Copy this file to '.env' and adjust the variables as needed.
# =======================================================================

# Database URL configuration (defaults to SQLite: backend/tmpvl_audit.db)
# For SQLite, use 'sqlite:///backend/tmpvl_audit.db' (relative) or 'sqlite:////absolute/path/to/db.db'
DATABASE_URL=sqlite:///backend/tmpvl_audit.db

# Backend service binding host & port
HOST=127.0.0.1
PORT=8000

# React Frontend origin (used for CORS headers)
FRONTEND_URL=http://localhost:5173

# Logging configurations (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Maximum allowed file upload size (default: 52428800 bytes = 50MB)
MAX_UPLOAD_SIZE=52428800

# File storage directory locations (relative to project root or absolute paths)
UPLOAD_DIRECTORY=uploads
REPORT_DIRECTORY=reports
TEMPLATE_DIRECTORY=templates
LOG_DIRECTORY=logs
TEMP_DIRECTORY=temp

# Ingestion parser settings
PARSER_VERSION=2.0.0
